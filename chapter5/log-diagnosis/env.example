# Copy to .env and fill in your OpenAI Key (direct connection, one of these is required)
OPENAI_API_KEY=sk-your-key-here

# General fallback: when OPENAI_API_KEY is not configured, it automatically switches to OpenRouter;
# The default model gpt-5.6-luna (gpt-5.x) requires organizational real-name authentication for direct OpenAI connection,
# so when this key is set, OpenRouter will be prioritized (route openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: change the model (default gpt-5.6-luna)
# OPENAI_MODEL=gpt-5.6-luna

# Optional: switch providers (any service compatible with the OpenAI API, such as Moonshot / Volcengine Ark / local vLLM)
# Also replace OPENAI_API_KEY with the provider's key and OPENAI_MODEL with its model name
# OPENAI_BASE_URL=https://api.moonshot.cn/v1

# Optional: use when actually connecting to GitHub MCP (default is mock, no need to fill in)
# Must be used with python demo.py --create-issue to actually create an Issue online
# GITHUB_TOKEN=ghp_xxx
# GITHUB_REPO=owner/repo
# Optional: override the GitHub MCP Server startup command (default uses the official Docker image)
# GITHUB_MCP_COMMAND=docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN ghcr.io/github/github-mcp-server
