# Experiment 5-3 Environment Variables

# OpenAI API Key (direct connection, one of these must be set)
OPENAI_API_KEY=sk-your-key-here

# General fallback: when OPENAI_API_KEY is not configured, it automatically switches to OpenRouter;
# If the LLM baseline uses gpt-5.x (e.g., gpt-5.6-luna), a direct connection to OpenAI requires organizational identity verification,
# so when this key is set, the model will preferentially use OpenRouter (route openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=sk-or-your-key-here

# Model name used as the "small model" representative (core to this experiment, so the small model gpt-5.6-luna is kept by default; can be overridden with --small-model)
MODEL=gpt-5.6-luna

# Model name used as the "large model baseline" (optional; when set, demo.py automatically adds a third arm, can also be overridden with --big-model)
# BIG_MODEL=gpt-5.6-luna
