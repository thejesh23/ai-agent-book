# 至少配置一个 key（优先使用 OPENAI_API_KEY）
OPENAI_API_KEY=your_openai_api_key_here
# MOONSHOT_API_KEY=your_moonshot_api_key_here   # 可选，Kimi
# ARK_API_KEY=your_ark_api_key_here             # 可选，豆包

# 可选：切换到兼容 OpenAI 协议的服务端点
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：指定模型（默认 gpt-4o-mini）
# MODEL=gpt-4o-mini
