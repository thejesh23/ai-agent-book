# At least one key must be configured (OPENAI_API_KEY takes priority)
OPENAI_API_KEY=your_openai_api_key_here
# MOONSHOT_API_KEY=your_moonshot_api_key_here   # Optional, Kimi (kimi-k3)
# ARK_API_KEY=your_ark_api_key_here             # Optional, Doubao

# General fallback: if no direct key is configured, it will automatically route through OpenRouter;
# Additionally, the default model gpt-5.6-luna (gpt-5.x) will prioritize OpenRouter when this key is set,
# because directly calling gpt-5.6 via OpenAI requires organizational real-name verification.
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: switch to a service endpoint compatible with the OpenAI protocol
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: specify the model (default is gpt-5.6-luna)
# MODEL=gpt-5.6-luna
