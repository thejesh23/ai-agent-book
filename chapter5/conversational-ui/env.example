# One of the following is required: OpenAI API Key (this experiment reads this item)
OPENAI_API_KEY=your_openai_api_key_here

# General fallback: when OPENAI_API_KEY is not configured, it automatically switches to OpenRouter;
# The default model gpt-5.6-luna (gpt-5.x) requires organizational real-name authentication for direct OpenAI connection,
# so when this key is set, it will prioritize OpenRouter (route openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: switch to a service endpoint compatible with the OpenAI protocol
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: specify the model used by the custom Agent (default gpt-5.6-luna)
# MODEL=gpt-5.6-luna

# Optional: make the backend chatbot use real LLM conversations (default is echo mode)
# Equivalent to `python backend/main.py --model <model_name>`
# CHAT_MODEL=gpt-5.6-luna
