# Copy this file to .env and fill in your keys
# One of the following is required: OpenAI API Key (direct connection)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# General fallback: when OPENAI_API_KEY is not configured, it will automatically switch to OpenRouter (route openai/gpt-4o-mini).
# Only when MODEL is changed to a model requiring organizational identity verification, such as gpt-5.x, and this key is set,
# will OpenRouter be prioritized.
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: switch to a service endpoint compatible with the OpenAI protocol
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: default model (if not specified, gpt-4o-mini will be used)
MODEL=gpt-4o-mini
