# One of the following is required: OpenAI API Key (both narration generation and TTS can use the official OpenAI interface)
OPENAI_API_KEY=your_openai_api_key_here

# General fallback: when OPENAI_API_KEY is not configured, narration generation automatically switches to OpenRouter;
# however, OpenAI TTS is not available on OpenRouter, so audio will be degraded to an offline silent placeholder.
# The default narration model gpt-5.6-luna (gpt-5.x) requires organizational real-name authentication for direct OpenAI connection,
# so when this key is set, narration will preferentially use OpenRouter (route openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: custom endpoint compatible with the OpenAI protocol (default is official)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: narration generation model (default is gpt-5.6-luna)
# TEXT_MODEL=gpt-5.6-luna

# Optional: TTS model and voice (default is tts-1 / alloy)
# TTS_MODEL=tts-1
# TTS_VOICE=alloy
