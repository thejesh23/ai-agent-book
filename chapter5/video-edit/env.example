# One of the following is required: OpenAI API Key (in this experiment, gpt-5.6-luna is used for visual positioning/review + text planning)
OPENAI_API_KEY=your_openai_api_key_here

# General fallback: when OPENAI_API_KEY is not configured, it automatically switches to OpenRouter;
# The default model gpt-5.6-luna (gpt-5.x) requires organizational real-name authentication for direct OpenAI connection,
# so when this key is set, it will prioritize OpenRouter (route openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: custom endpoint compatible with the OpenAI protocol
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: specify the model (both default to gpt-5.6-luna; the vision model must support image input)
# TEXT_MODEL=gpt-5.6-luna
# VISION_MODEL=gpt-5.6-luna
