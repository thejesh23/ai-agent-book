# Required (one of the two): OpenAI API Key (this experiment uses gpt-5.6-luna for visual review + text generation)
OPENAI_API_KEY=your_openai_api_key_here

# General fallback: when OPENAI_API_KEY is not configured, automatically switch to OpenRouter;
# The default model gpt-5.6-luna (gpt-5.x) requires organizational real-name verification for direct OpenAI connection,
# so when this key is set, it will prioritize OpenRouter (route openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: custom endpoint compatible with the OpenAI protocol
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: specify the model (both default to gpt-5.6-luna; the vision model must support image input)
# TEXT_MODEL=gpt-5.6-luna
# VISION_MODEL=gpt-5.6-luna
