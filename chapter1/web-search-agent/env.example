# Kimi API Configuration
# Obtain your API Key from https://platform.moonshot.cn/
MOONSHOT_API_KEY=your-api-key-here

# Optional configuration
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# DEFAULT_MODEL=kimi-k3
# MAX_SEARCH_ITERATIONS=5
# SEARCH_TIMEOUT=30

# General fallback: when MOONSHOT_API_KEY is missing, if OPENROUTER_API_KEY is set,
# requests will automatically be routed through OpenRouter. Note: Kimi's built-in $web_search tool
# is not available on OpenRouter. In this fallback mode, the model responds solely based on its own knowledge
# (no real-time web search), and uses OPENROUTER_MODEL (default openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
# OPENROUTER_MODEL=openai/gpt-5.6-luna
