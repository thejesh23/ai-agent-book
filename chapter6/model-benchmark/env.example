# Copy as .env or directly export to environment variables.
# Only fill in the keys you have; providers with missing keys will be skipped automatically.

# OpenAI Official (for gpt-5.6-luna / kimi-k3 / doubao-1.6)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter fallback: when OPENAI_API_KEY is not set, OpenAI native entries automatically route through OpenRouter
# (model name mapping gpt-* -> openai/*). Direct connection for gpt-5.x requires organizational real-name verification; as long as this key is set,
# it will prioritize OpenRouter.
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# Moonshot Kimi (base_url is already configured in code as https://api.moonshot.cn/v1)
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ByteDance Volcano Ark / Doubao (base_url is already configured as https://ark.cn-beijing.volces.com/api/v3)
ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
