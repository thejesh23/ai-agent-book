# Copy as .env or export directly. Default model is gpt-5.6-luna (current affordable flagship).
# First choice: OPENAI_API_KEY; if not set, automatically fall back to OPENROUTER_API_KEY (via OpenRouter compatible endpoint).
# Note: gpt-5.x direct connection to OpenAI requires organization real-name verification. As long as OPENROUTER_API_KEY is set, it will be used first.
OPENAI_API_KEY=sk-your-openai-key

# OpenRouter fallback key (used when OPENAI_API_KEY is absent; model names are auto-mapped gpt-* -> openai/*)
# OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Optional: override the default model (default is gpt-5.6-luna)
# COST_DEMO_MODEL=gpt-5.6-luna
