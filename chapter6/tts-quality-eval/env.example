# Copy to .env or export directly. TTS synthesis and Whisper back-translation must go through OpenAI direct connection, requiring the key below.
# Default LLM evaluation model is gpt-5.6-luna (current cost-effective flagship).
OPENAI_API_KEY=sk-your-openai-key

# Optional: OpenRouter fallback for LLM Rubric evaluation (only evaluation chat calls can fall back; TTS/Whisper cannot).
# gpt-5.x direct connection to OpenAI requires organizational real-name authentication. As long as this key is set, evaluation will prioritize OpenRouter.
# OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Optional: Only needed when using `python demo.py --gemini` to let Gemini multimodal directly listen to audio for evaluation.
# Default Gemini evaluation model is gemini-3.5-flash (verified to support audio input).
# Default (without --gemini) evaluation is Whisper back-translation + gpt-5.6-luna Rubric, no key required.
# GEMINI_API_KEY=your-gemini-key

# Optional: When cross-provider horizontal comparison is performed (`--providers openai,elevenlabs,minimax,...`), configure as needed.
# Rows corresponding to unconfigured providers will be marked as failed, without affecting the full table. See details via `python demo.py --list-providers`.
# ELEVENLABS_API_KEY=your-elevenlabs-key
# FISH_API_KEY=your-fishaudio-key            # Also compatible with alias FISHAUDIO_API_KEY
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_GROUP_ID=your-minimax-group-id
# DOUBAO_APP_ID=your-volcengine-app-id
# DOUBAO_ACCESS_TOKEN=your-volcengine-access-token
