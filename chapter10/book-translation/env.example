# Copy to .env and fill in your key

# Preferred: OPENAI_API_KEY (direct connection to OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: model and endpoint (default is currently the affordable flagship gpt-5.6-luna)
OPENAI_MODEL=gpt-5.6-luna
# OPENAI_BASE_URL=https://api.openai.com/v1

# General fallback: if OPENAI_API_KEY is not set, it will automatically switch to OPENROUTER_API_KEY via OpenRouter,
# and map the model name to its namespace (gpt-5.6-luna -> openai/gpt-5.6-luna, claude-* ->
# anthropic/claude-opus-4.8). Note: the gpt-5.6 series requires organization verification for direct OpenAI connections; using
# OpenRouter is more convenient—just fill in OPENROUTER_API_KEY (leave OPENAI_API_KEY empty) to force OpenRouter.
# OPENROUTER_API_KEY=sk-or-your-openrouter-key
