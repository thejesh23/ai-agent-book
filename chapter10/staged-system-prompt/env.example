# Copy this file to .env and fill it in, or use export to set environment variables directly.

# Primary: OpenAI API Key
OPENAI_API_KEY=sk-your-key-here

# Optional: base_url compatible with the OpenAI protocol, defaults to the official address
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: model name, defaults to the current affordable flagship gpt-5.6-luna
OPENAI_MODEL=gpt-5.6-luna

# Optional: sampling temperature, defaults to 0.3
OPENAI_TEMPERATURE=0.3

# ---------------------------------------------------------------------------
# General fallback: if OPENAI_API_KEY is not set, it automatically switches to
# OPENROUTER_API_KEY to go through OpenRouter, and maps the model name to its
# namespace (gpt-5.6-luna -> openai/gpt-5.6-luna, claude-* ->
# anthropic/claude-opus-4.8). Note: the gpt-5.6 series requires organization
# verification for direct OpenAI connections; going through OpenRouter is more
# convenient—just fill in OPENROUTER_API_KEY (leave OPENAI_API_KEY empty) to
# force routing through OpenRouter.
# OPENROUTER_API_KEY=sk-or-your-openrouter-key
#
# You can also switch to other vendors compatible with the OpenAI protocol, for example:
# Kimi (Moonshot):
#   OPENAI_API_KEY=$MOONSHOT_API_KEY
#   OPENAI_BASE_URL=https://api.moonshot.cn/v1
#   OPENAI_MODEL=kimi-k3
# Doubao (Volcengine Ark):
#   OPENAI_API_KEY=$ARK_API_KEY
#   OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#   OPENAI_MODEL=<your-endpoint-id>
