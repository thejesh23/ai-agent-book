# Copy to .env and fill in as needed. Leaving everything blank will still work (uses offline keyword matching, results are reproducible).

# —— Optional: Let sub-agents use a real LLM to determine "whether the page contains the answer" ——
# Preferred: OPENAI_API_KEY (direct connection to OpenAI), defaults to the current affordable flagship gpt-5.6-luna.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
# Fill in when using a custom OpenAI-compatible gateway, e.g., Moonshot / Volcano Ark ARK:
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=kimi-k3

# General fallback: If OPENAI_API_KEY is not set, automatically switch to OPENROUTER_API_KEY via OpenRouter,
# and map the model name to its namespace (gpt-5.6-luna -> openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=

# Note: Real LLM judgment requires both USE_LLM=1 and one of the above keys configured; otherwise, it falls back to offline keyword matching.
# Set to 1/true to enable real LLM judgment (default: leave blank = offline keyword matching, results reproducible):
USE_LLM=
