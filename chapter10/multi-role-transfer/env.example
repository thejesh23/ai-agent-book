# Copy to .env and fill in. At least one of OPENAI_API_KEY or OPENROUTER_API_KEY is required.

# Primary: OpenAI API Key (direct connection to OpenAI)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: custom base_url (default https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: custom model (default current affordable flagship gpt-5.6-luna)
# OPENAI_MODEL=gpt-5.6-luna

# General fallback: if OPENAI_API_KEY is not set, automatically use OPENROUTER_API_KEY via OpenRouter,
# and map the model name to its namespace (gpt-5.6-luna -> openai/gpt-5.6-luna).
# Note: The gpt-5.6 series requires organization verification for direct OpenAI connection;
# using OpenRouter is more convenient—
# just fill in OPENROUTER_API_KEY (leave OPENAI_API_KEY empty) to force routing through OpenRouter.
# OPENROUTER_API_KEY=sk-or-your-openrouter-key
