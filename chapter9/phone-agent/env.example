# Fill in after copying as .env. This experiment uses a chat LLM to drive a ReAct Agent simulating the callee.
# Configure at least one of OPENAI_API_KEY or OPENROUTER_API_KEY.

# Method 1 (recommended): OpenRouter. Direct connection to OpenAI for gpt-5.6* requires organizational identity verification; using OpenRouter bypasses this step.
OPENROUTER_API_KEY=

# Method 2: Direct connection to OpenAI. If set, direct connection takes priority; the default model is gpt-5.6-luna (can be overridden with OPENAI_MODEL).
# OPENAI_API_KEY=

# Optional: Chat model (default gpt-5.6-luna). When falling back to OpenRouter, it is automatically mapped to openai/gpt-5.6-luna.
# OPENAI_MODEL=gpt-5.6-luna

# Optional: Switch to Moonshot's kimi-k3 (OpenAI-compatible gateway) — fill the kimi key into OPENAI_API_KEY,
# and set the base_url and model:
# OPENAI_API_KEY=<Your Moonshot Key>
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=kimi-k3

# Resolution priority: OPENAI_API_KEY (optional OPENAI_BASE_URL gateway) > OPENROUTER_API_KEY (auto-maps model).
#
# —— Only needed when actually connecting to the PineClaw Voice API (not required for this simulation) ——
# PINECLAW_API_KEY=
