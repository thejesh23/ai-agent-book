# OpenAI API configuration (required): Both end-to-end gpt-audio and cascaded ASR(whisper-1)/TTS(tts-1) are
# audio endpoints, only available through direct OpenAI connection—OpenRouter has no audio endpoints, so this experiment must provide a direct OpenAI API key.
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Default model for cascaded pure-text LLM reasoning is gpt-5.6-luna. If OPENROUTER_API_KEY is set,
# the LLM reasoning will automatically switch to OpenRouter (mapped to openai/gpt-5.6-luna), bypassing the organizational identity verification required for direct gpt-5.6* connection;
# ASR/TTS/end-to-end audio still use the OpenAI direct key above.
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# LLM_MODEL=gpt-5.6-luna

# End-to-end speech-to-speech model (optional, default gpt-audio)
# The key must have access to gpt-audio; if other available s2s models exist, override here.
# E2E_MODEL=gpt-audio

# Real Step-Audio R1 (optional): The end-to-end speech reasoning model from the book, no public endpoint,
# requires multi-GPU self-deployment. After deployment, write the service address here to switch the end-to-end path to the real Step-Audio R1;
# leave empty to use the gpt-audio above as the end-to-end representative.
# STEP_AUDIO_ENDPOINT=http://localhost:8000/v1/audio/chat
