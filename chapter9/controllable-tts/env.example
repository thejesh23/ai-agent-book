# OpenAI API Key (valid, used for calling TTS)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the preferred TTS model. Default is gpt-4o-mini-tts (supports instructions style control),
# if unavailable, the code will automatically fall back to tts-1.
# TTS_MODEL=gpt-4o-mini-tts

# Note: Experiment 9-5 in the book uses Fish Audio (no valid key available), this project uses OpenAI TTS instead to demonstrate
# the same "control token -> stylized speech" approach.
#
# This experiment only uses the TTS speech synthesis endpoint (gpt-4o-mini-tts / tts-1). Such audio endpoints are only available
# via direct OpenAI connection—OpenRouter only handles chat completions and has no audio synthesis endpoint, so a direct OpenAI API Key
# must be used here, and cannot fall back to OPENROUTER_API_KEY. Offline operations like viewing the voice library/token mapping
# (--list-voices / --dump-mapping) require no key at all.
