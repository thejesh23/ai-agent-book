# Copy to .env and fill in your key
# This experiment uses OpenAI by default (both chat and embeddings use OpenAI)
# If you don't have a key yet, you can first run the offline self-check: python demo.py --offline (local embeddings + mock model, no key needed below)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Unified fallback: if OPENAI_API_KEY is not set, but OPENROUTER_API_KEY is set, then chat automatically
# switches to OpenRouter (model mapped to openai/gpt-5.6-luna, etc.); since OpenRouter has no embeddings
# interface, tool retrieval falls back to local hash embeddings.
# OPENROUTER_API_KEY=sk-or-...

# Optional: chat model, default gpt-5.6-luna
# MODEL=gpt-5.6-luna

# Optional: embedding model, default text-embedding-3-small (only used for direct OpenAI connection)
# EMBED_MODEL=text-embedding-3-small
