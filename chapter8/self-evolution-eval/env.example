# === Experiment 8-6 Environment Variable Example: Copy to .env and fill in your Key ===

# Select provider: openai (default) | moonshot | ark
PROVIDER=openai

# OpenAI (used by default, default model gpt-5.6-luna)
OPENAI_API_KEY=your_openai_api_key_here

# Unified fallback: if the Key for the above provider is missing, but OPENROUTER_API_KEY is set,
# it will automatically switch to OpenRouter and map the model name to openai/gpt-5.6-luna, etc.
# OPENROUTER_API_KEY=sk-or-...

# Alternatives: Kimi / Volcano Ark (use when PROVIDER is set to moonshot or ark)
# MOONSHOT_API_KEY=your_moonshot_api_key_here
# ARK_API_KEY=your_ark_api_key_here

# Model used by the Agent under test for tool generation (default gpt-5.6-luna)
AGENT_MODEL=gpt-5.6-luna
# Model used by LLM-as-a-Judge for scoring (default gpt-5.6-luna)
JUDGE_MODEL=gpt-5.6-luna
TEMPERATURE=0.2
