# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Unified fallback: if OPENAI_API_KEY is not set but OPENROUTER_API_KEY is set, then gpt-* models
# automatically route through OpenRouter (mapped to openai/gpt-5.6-luna, etc.). Default model: gpt-5.6-luna.
# OPENROUTER_API_KEY=sk-or-...

# Optional: Browser-use configuration
BROWSER_USE_DEBUG_LOG_FILE=./logs/debug.log
BROWSER_USE_INFO_LOG_FILE=./logs/info.log

# Optional: Headless mode for production
HEADLESS_MODE=false
