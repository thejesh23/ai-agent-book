# Copy this file to .env and fill in your real keys (demo.py will load it automatically)

# ===== Default: Use OpenAI =====
OPENAI_API_KEY=sk-your-openai-key

# Default model is gpt-5.6-luna, can be overridden:
# LLM_MODEL=gpt-5.6-luna

# ===== Fallback: OpenRouter =====
# If the provider's Key above is missing, but OPENROUTER_API_KEY is set, it will automatically switch to
# OpenRouter and map the model name to openai/gpt-5.6-luna, etc.
# OPENROUTER_API_KEY=sk-or-...

# ===== Optional: Switch to a domestic provider compatible with the OpenAI API =====
# LLM_PROVIDER values: openai (default) / moonshot / ark
# LLM_PROVIDER=moonshot
# MOONSHOT_API_KEY=sk-your-moonshot-key

# LLM_PROVIDER=ark
# ARK_API_KEY=your-ark-key
# ARK_MODEL=your-ark-endpoint-id     # Volcengine Ark requires the inference endpoint ID

# Sampling temperature (default 0, ensures reproducible results)
# LLM_TEMPERATURE=0
