# ============================================================
# Experiment 8-5 Self-Evolving Agent · Environment Variable Example
# Copy to .env or export directly into the environment
# ============================================================

# Default uses OpenAI (gpt-5.6-luna), function calling
OPENAI_API_KEY=sk-your-openai-key

# Unified fallback: if the above provider's Key is missing but OPENROUTER_API_KEY is set,
# it will automatically switch to OpenRouter and map the model name to openai/gpt-5.6-luna, etc.
# OPENROUTER_API_KEY=sk-or-...

# Optional: switch to another OpenAI-compatible provider (choose one of three), and override the model name
# LLM_PROVIDER=openai        # openai | moonshot | ark
# LLM_MODEL=gpt-5.6-luna     # Override the default model
# MOONSHOT_API_KEY=sk-...    # When LLM_PROVIDER=moonshot
# ARK_API_KEY=...            # When LLM_PROVIDER=ark

# Note: This experiment's web_search uses DuckDuckGo, no search API key is needed.
