# tau-bench ablation experiment LLM configuration (routed via litellm)
# Primary: direct OpenAI connection (default model gpt-5.6-luna)
OPENAI_API_KEY=your_openai_api_key_here

# General fallback: if OPENAI_API_KEY is not set but OPENROUTER_API_KEY is configured, automatically switch to
# OpenRouter (bare ids like gpt-5.6-luna will be prefixed as openai/gpt-5.6-luna, provider switched to openrouter).
# You can also explicitly use an id with "/" (e.g., --model openai/gpt-5) to go through OpenRouter.
# OPENROUTER_API_KEY=sk-or-...
