# Moonshot / Kimi API configuration (this experiment primarily uses the official Moonshot API)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# General fallback: if neither MOONSHOT_API_KEY nor KIMI_API_KEY is set, and OPENROUTER_API_KEY is configured,
# it will automatically switch to OpenRouter (kimi-* model names will be mapped to moonshotai/kimi-k2).
# OPENROUTER_API_KEY=sk-or-...
