# This experiment primarily uses a local Ollama small model (qwen3:0.6b), no cloud API key required.
# Just start Ollama first: ollama serve

# General fallback: when Ollama is unavailable (not running/unreachable) and OPENROUTER_API_KEY is set,
# automatically switch to OpenRouter (default hosted model openai/gpt-5.6-luna).
# OPENROUTER_API_KEY=sk-or-...

# Optional: force OpenRouter fallback (point Ollama to an unreachable port)
# OLLAMA_HOST=http://127.0.0.1:1
