# API Configuration
KIMI_API_KEY=your-kimi-api-key-here

# General fallback: when KIMI_API_KEY is not set, if OPENROUTER_API_KEY is configured, automatically switch to
# OpenRouter (kimi-* will be mapped to moonshotai/kimi-k2).
# OPENROUTER_API_KEY=sk-or-...

# Optional: LLM Provider Settings
LLM_PROVIDER=kimi
LLM_MODEL=kimi-k3

# System Hint Features (all default to true)
ENABLE_TIMESTAMPS=true
ENABLE_TOOL_COUNTER=true
ENABLE_TODO_LIST=true
ENABLE_DETAILED_ERRORS=true
ENABLE_SYSTEM_STATE=true

# Formatting Options
TIMESTAMP_FORMAT=%Y-%m-%d %H:%M:%S
SIMULATE_TIME_DELAY=false

# Execution Options
MAX_ITERATIONS=20
VERBOSE=false
COMMAND_TIMEOUT=30
