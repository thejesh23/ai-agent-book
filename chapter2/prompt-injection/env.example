# OpenAI configuration (this experiment uses only the official OpenAI API)
OPENAI_API_KEY=your_openai_api_key_here

# Model (default gpt-4o-mini): This experiment deliberately uses this weaker, "intentionally breakable" baseline
# to demonstrate the comparative curve of "defenses progressively strengthened -> injection success rate declines";
# switching to a stronger model (e.g., gpt-5.6-luna) would resist all injections even under D1 (no defense),
# flattening the pedagogical comparison.
OPENAI_MODEL=gpt-4o-mini

# Optional: Custom API base_url (default is official; do not point to expired third-party gateways)
# OPENAI_BASE_URL=

# General fallback: when OPENAI_API_KEY is not set, if OPENROUTER_API_KEY is configured, automatically switch to
# OpenRouter (gpt-* will be mapped to openai/…).
# OPENROUTER_API_KEY=sk-or-...

# Optional: Number of trials per attack x defense combination (recommended 3-5, to control cost)
TRIALS=4
