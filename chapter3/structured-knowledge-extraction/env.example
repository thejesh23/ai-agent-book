# Copy to .env and fill in your OpenAI API Key
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Override the default model (default gpt-5.6-luna)
# OPENAI_MODEL=gpt-5.6-luna

# OpenRouter generic fallback (optional): If OPENAI_API_KEY is not set but OPENROUTER_API_KEY is,
# the chat LLM will automatically route to OpenRouter (gpt-5.6-luna -> openai/gpt-5.6-luna;
# can be overridden with OPENROUTER_MODEL).
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=openai/gpt-5.6-luna
